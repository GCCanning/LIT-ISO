    "__POSE_SEQUENCE_DIR__": "folder containing frame_### pose images",
    "__SEED__": "integer seed",
    "__FRAME_COUNT__": "number of output frames",
    "__WIDTH__": "generation width",
    "__HEIGHT__": "generation height",
    "__OUTPUT_PREFIX__": "ComfyUI output prefix"
  },
  "model_contract": {
    "text_encoder_folder": "C:/Projects/ComfyUI/models/text_encoders",
    "diffusion_model_folder": "C:/Projects/ComfyUI/models/diffusion_models",
    "vae_folder": "C:/Projects/ComfyUI/models/vae",
    "clip_vision_folder": "C:/Projects/ComfyUI/models/clip_vision",
    "preferred_family": "WanVideo One-to-All pose-control, quantized/low-vram variant if available"
  },
  "spriteforge_postprocess": {
    "extract_frames": true,
    "cleanup": "Tools/SpriteForge/run_lane_b_animation.py",
