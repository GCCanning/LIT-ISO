{
  "schema": "lit-iso.spriteforge.workflow-template.v1",
  "template_status": "binding-required",
  "engine": "video",
  "lane": "B",
  "name": "one_to_all_pose_i2v",
  "upstream_node_pack": "C:/Projects/ComfyUI/custom_nodes/ComfyUI-WanVideoWrapper",
